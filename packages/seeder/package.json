{
  "name": "@joakimbugge/seeder",
  "version": "0.3.0",
  "description": "ORM-agnostic decorator-based entity seeding",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joakimbugge/seeders.git"
  },
  "homepage": "https://github.com/joakimbugge/seeders#readme",
  "bugs": "https://github.com/joakimbugge/seeders/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm run build",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "fmt": "oxfmt src tests",
    "fmt:check": "oxfmt --check src tests"
  },
  "keywords": [
    "seeder",
    "decorator",
    "database",
    "seed"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.19.0"
  },
  "peerDependencies": {
    "reflect-metadata": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "reflect-metadata": {
      "optional": true
    }
  },
  "dependencies": {
    "dependency-graph": "^1.0.0",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "reflect-metadata": "^0.2.2"
  }
}
