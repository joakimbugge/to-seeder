{
  "name": "@joakimbugge/typeorm-seeder",
  "version": "0.12.1",
  "description": "Decorator-based seeder library for TypeORM",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joakimbugge/seeders.git"
  },
  "homepage": "https://github.com/joakimbugge/seeders#readme",
  "bugs": "https://github.com/joakimbugge/seeders/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "@joakimbugge/typeorm-seeder": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm run build",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "fmt": "oxfmt src tests",
    "fmt:check": "oxfmt --check src tests"
  },
  "keywords": [
    "typeorm",
    "seeder",
    "decorator",
    "database",
    "seed"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.19.0"
  },
  "peerDependencies": {
    "reflect-metadata": ">=0.1.0",
    "ts-node": ">=10.0.0",
    "typeorm": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "ts-node": {
      "optional": true
    }
  },
  "devDependencies": {
    "reflect-metadata": "^0.2.2",
    "typeorm": "1.0.0-nightly.20260405"
  },
  "dependencies": {
    "@joakimbugge/seeder": "workspace:^",
    "tinyglobby": "^0.2.16"
  }
}
