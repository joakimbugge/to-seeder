{
  "name": "@joakimbugge/typeorm-seeder",
  "version": "0.4.1",
  "description": "Decorator-based seeder library for TypeORM",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joakimbugge/to-seeder.git"
  },
  "homepage": "https://github.com/joakimbugge/to-seeder#readme",
  "bugs": "https://github.com/joakimbugge/to-seeder/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm run build",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "fmt": "oxfmt src tests",
    "fmt:check": "oxfmt --check src tests"
  },
  "keywords": [
    "typeorm",
    "seeder",
    "decorator",
    "database",
    "seed"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16.13.0"
  },
  "peerDependencies": {
    "reflect-metadata": ">=0.1.0",
    "typeorm": ">=0.3.0"
  },
  "devDependencies": {
    "reflect-metadata": "^0.2.2",
    "typeorm": "1.0.0-nightly.20260327"
  },
  "dependencies": {
    "dependency-graph": "^1.0.0"
  }
}
