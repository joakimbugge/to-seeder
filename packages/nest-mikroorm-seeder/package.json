{
  "name": "@joakimbugge/nest-mikroorm-seeder",
  "version": "0.2.0",
  "description": "NestJS module for @joakimbugge/mikroorm-seeder",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joakimbugge/seeders.git"
  },
  "homepage": "https://github.com/joakimbugge/seeders#readme",
  "bugs": "https://github.com/joakimbugge/seeders/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm run build",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "fmt": "oxfmt src tests",
    "fmt:check": "oxfmt --check src tests"
  },
  "keywords": [
    "mikroorm",
    "seeder",
    "decorator",
    "database",
    "seed",
    "nestjs"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16.13.0"
  },
  "peerDependencies": {
    "@joakimbugge/seeder": ">=0.1.0",
    "@joakimbugge/mikroorm-seeder": ">=0.1.1",
    "@mikro-orm/core": ">=7.0.0",
    "@mikro-orm/nestjs": ">=7.0.0",
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "reflect-metadata": ">=0.1.0"
  },
  "devDependencies": {
    "@joakimbugge/seeder": "workspace:^",
    "@joakimbugge/mikroorm-seeder": "workspace:^",
    "@mikro-orm/core": "^7.0.9",
    "@mikro-orm/decorators": "^7.0.0",
    "@mikro-orm/nestjs": "^7.0.0",
    "@mikro-orm/sqlite": "^7.0.8",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "reflect-metadata": "^0.2.2"
  }
}
